# Supabase Configuration
# The URL of your Supabase project (found in Project Settings > API)
VITE_SUPABASE_URL=

# The Anon/Public Key of your Supabase project (found in Project Settings > API)
VITE_SUPABASE_ANON_KEY=

# The Service Role Key (secret, backend/server-only - DO NOT expose or prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=

# Google Generative AI API Key (get it from https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=
